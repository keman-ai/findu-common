<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.findu.common.mapper.UserExtraInfoMapper">

    <resultMap id="UserExtraInfoResultMap" type="com.findu.common.repository.po.UserExtraInfoPO">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="infoKey" column="info_key"/>
        <result property="infoValue" column="info_value"/>
        <result property="gmtCreate" column="gmt_create"/>
        <result property="gmtModified" column="gmt_modified"/>
    </resultMap>

    <select id="selectByUserId" resultMap="UserExtraInfoResultMap">
        SELECT id, user_id, info_key, info_value, gmt_create, gmt_modified
        FROM user_extra_info
        WHERE user_id = #{userId}
    </select>

    <insert id="batchInsert"
            parameterType="java.util.List"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO user_extra_info (user_id, info_key, info_value, gmt_create, gmt_modified)
        VALUES
        <foreach collection="items" item="item" separator=",">
            (
            #{item.userId},
            #{item.infoKey},
            #{item.infoValue},
            #{item.gmtCreate},
            #{item.gmtModified}
            )
        </foreach>
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM user_extra_info
        WHERE user_id = #{userId}
    </delete>
</mapper>
